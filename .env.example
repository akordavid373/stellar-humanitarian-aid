# Stellar Configuration
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK=testnet
AID_DISTRIBUTION_ACCOUNT=YOUR_STELLAR_ACCOUNT_PUBLIC_KEY
AID_DISTRIBUTION_SECRET=YOUR_STELLAR_ACCOUNT_SECRET_KEY

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Security
SESSION_SECRET=your_session_secret_here
API_RATE_LIMIT=100

# Database (if implemented)
DATABASE_URL=postgresql://username:password@localhost:5432/stellar_aid_network

# Redis (if implemented)
REDIS_URL=redis://localhost:6379

# Monitoring
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_here
